# Mockarty Environment Configuration
# Copy this file to .env and fill in the values.
# cp .env.example .env

# =============================================================================
# REQUIRED - Database
# =============================================================================

POSTGRES_USER=mockarty
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=mockarty
POSTGRES_PORT=5432

# =============================================================================
# REQUIRED - Admin Credentials
# =============================================================================

# Bootstrap admin credentials (change immediately after first login)
FIRST_ADMIN_LOGIN=admin
FIRST_ADMIN_PASSWORD=change_me_in_production

# =============================================================================
# OPTIONAL - Version
# =============================================================================

# Docker image tag (use a specific version for production)
VERSION=latest

# =============================================================================
# OPTIONAL - Admin Node Ports
# =============================================================================

# HTTP port — Web UI, REST API, mock HTTP traffic
HTTP_PORT=5770

# HTTPS port — TLS-terminated HTTP (configure HTTPS_CERT_FILE/HTTPS_KEY_FILE to enable)
HTTPS_PORT=5771

# MCP (Model Context Protocol) server port
MCP_PORT=5772

# Internal coordinator gRPC port — resolver/runner nodes connect here
COORDINATOR_PORT=5773

# =============================================================================
# OPTIONAL - Redis (caching layer for distributed mode)
# =============================================================================

REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# OPTIONAL - Logging
# =============================================================================

# Logging level: debug | info | warn | error
LOG_LEVEL=info

# =============================================================================
# OPTIONAL - Auth
# =============================================================================

# Base URL for OAuth redirects
AUTH_BASE_URL=http://localhost:5770

# =============================================================================
# DISTRIBUTED MODE - Resolver & Runner Tokens
# =============================================================================
# Generate these tokens in the admin UI (Settings > API Tokens)
# after starting the admin node for the first time.

# API token for resolver authentication
RESOLVER_API_TOKEN=

# API token for runner authentication
RUNNER_API_TOKEN=

# =============================================================================
# OPTIONAL - Runner Configuration
# =============================================================================

# Maximum concurrent test tasks per runner
MAX_CONCURRENT_TASKS=3

# Runner capabilities (comma-separated)
RUNNER_CAPABILITIES=api_test,performance
